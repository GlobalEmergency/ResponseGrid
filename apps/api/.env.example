DATABASE_URL=postgres://reliefhub:reliefhub@localhost:5433/reliefhub
REDIS_URL=redis://localhost:6380
PORT=3000
JWT_SECRET=dev-secret-change-me

# Social login (Google OAuth)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${OAUTH_CALLBACK_BASE}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social login (Facebook OAuth)
# Create credentials at https://developers.facebook.com/apps
# Valid OAuth Redirect URI: ${OAUTH_CALLBACK_BASE}/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Base URL of this API as seen from the OAuth provider (used for callback URLs)
OAUTH_CALLBACK_BASE=http://localhost:3000

# Frontend URL — after OAuth the browser is redirected here with the token in the fragment
FRONTEND_URL=http://localhost:3001
