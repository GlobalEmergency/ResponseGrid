DATABASE_URL=postgres://reliefhub:reliefhub@localhost:5433/reliefhub
REDIS_URL=redis://localhost:6380
PORT=3000
JWT_SECRET=dev-secret-change-me

# Social login (Google OAuth)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${OAUTH_CALLBACK_BASE}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social login (Facebook OAuth)
# Create credentials at https://developers.facebook.com/apps
# Valid OAuth Redirect URI: ${OAUTH_CALLBACK_BASE}/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Base URL of this API as seen from the OAuth provider (used for callback URLs)
OAUTH_CALLBACK_BASE=http://localhost:3000

# Frontend URL — after OAuth the browser is redirected here with the token in the fragment
FRONTEND_URL=http://localhost:3001

# File storage backend
# Options: (unset or any other value) → local disk (apps/api/uploads/)
#          s3                          → AWS S3 (requires S3_BUCKET; AWS credentials
#                                        resolved via SDK default chain: IAM role,
#                                        environment variables, shared credentials file)
# FILE_STORAGE=s3

# S3 bucket name — required when FILE_STORAGE=s3
# S3_BUCKET=my-reliefhub-bucket

# AWS region for the S3 client — defaults to us-east-1 when FILE_STORAGE=s3
# AWS_REGION=eu-west-1
